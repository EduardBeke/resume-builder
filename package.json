{
  "name": "resume-builder",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate-json-schema": "ts-json-schema-generator --path src/app/types/resume-schema.ts -t ResumeSchema -o public/resume-builder.json",
    "prestart": "pnpm generate-json-schema",
    "start": "ng serve",
    "prebuild": "pnpm generate-json-schema",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@jsverse/transloco": "^8.3.0",
    "@jsverse/transloco-utils": "^8.3.0",
    "@primeuix/themes": "^2.0.3",
    "monaco-editor": "^0.55.1",
    "ngx-monaco-editor-v2": "^21.1.4",
    "ngx-print": "^21.2.0",
    "ngx-printer": "^1.9.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.7",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
